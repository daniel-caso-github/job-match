{
  "title": "Job Match Pipeline",
  "uid": "job-match-pipeline",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Jobs procesados por etapa",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pipeline_jobs_total",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Duración por etapa (p95)",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(pipeline_stage_duration_seconds_bucket[1h]))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Llamadas a Gemini por estado",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(gemini_requests_total[5m])",
          "legendFormat": "{{type}} / {{status}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latencia Gemini (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(gemini_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 {{type}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(gemini_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{type}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Distribución de LLM scores",
      "type": "histogram",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(llm_score_bucket[1h])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP request rate por endpoint",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTP latencia p95 por endpoint",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Logs — API",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=~\"api|airflow-scheduler\"}",
          "refId": "A",
          "maxLines": 500
        }
      ]
    }
  ]
}
