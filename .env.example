# Copy this file to .env and fill in real values. .env is gitignored.
#
# Gemini API key (free tier ok): get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Postgres connection. The default below targets the `app-db` service inside the
# compose network. Override only if you point the app at an external DB.
DATABASE_URL=postgresql+psycopg://app:app@app-db:5432/jobmatch

# Airflow secrets — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=change-me

# Adzuna (aggregator, free key): register at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=gb   # country code: gb, us, es, au, br, ca, de, fr, nz, za ...

# Jooble (aggregator, free key): request at https://jooble.org/api/about
JOOBLE_API_KEY=

# Matching thresholds (optional — already have defaults in Settings)
# SEMANTIC_THRESHOLD=0.65
# TOP_K_FOR_LLM=30
